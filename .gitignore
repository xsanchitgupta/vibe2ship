# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep secrets out, but commit the PUBLIC client keys so Cloud Run
# bakes NEXT_PUBLIC_* into the build. (.env.production holds only public values.)
.env*
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
